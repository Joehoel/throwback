{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "jsxSingleQuote": false,
  "trailingComma": "all",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "ignorePatterns": [
    "node_modules/**",
    "dist/**",
    "build/**",
    ".vinxi/**",
    ".output/**",
    "spike/**",
    "src/routeTree.gen.ts",
    "worker-configuration.d.ts",
    "drizzle/meta/**",
    "package-lock.json"
  ]
}
