# Template for the gitignored .env. Copy to `.env` and fill in the real token:
#   cp .env.example .env
# sentry-cli auto-loads .env from the current directory (SENTRY_LOAD_DOTENV is on by default).
# Get a token at https://sentry.io → Settings → Auth Tokens, or run `sentry-cli login`.
SENTRY_AUTH_TOKEN=
